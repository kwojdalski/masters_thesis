direction: down

# ─────────────────────────────────────────────
# CLI Entry Points  (all commands are subcommands of src/cli.py)
# ─────────────────────────────────────────────
cli: CLI Entry Points {
  style.fill: "#f0f9ff"
  style.stroke: "#0369a1"

  cli_fr: "feature-research\nuv run python src/cli.py feature-research\n  --config <yaml>" {
    shape: step
    style.fill: "#e0f2fe"
  }

  cli_prepare: "prepare-data\nuv run python src/cli.py prepare-data\n  --scenario <name>  [--config-override key=value]\n  Rich progress bar; caches result to data/prepared/" {
    shape: step
    style.fill: "#e0f2fe"
  }

  cli_peek: "peek\nuv run python src/cli.py peek\n  --scenario <name>\n  Inspect prepared dataset: shapes · splits · columns" {
    shape: step
    style.fill: "#e0f2fe"
  }

  cli_train: "train\nuv run python src/cli.py train\n  --scenario <name>  [--checkpoint-path <ckpt>]\n  [--config-override key=value]" {
    shape: step
    style.fill: "#e0f2fe"
  }

  cli_evaluate: "evaluate\nuv run python src/cli.py evaluate\n  --config <yaml>" {
    shape: step
    style.fill: "#e0f2fe"
  }

  cli_dashboard: "dashboard\nuv run python src/cli.py dashboard\n  --port 8080  (launches MLflow UI)" {
    shape: step
    style.fill: "#e0f2fe"
  }

  cli_validate: "validate\nuv run python src/cli.py validate\n  --scenario <name>  (config validation only — no run)" {
    shape: step
    style.fill: "#e0f2fe"
  }
}

# ─────────────────────────────────────────────
# Stage 1 – Data Acquisition
# ─────────────────────────────────────────────
acquire: Data Acquisition {
  style.fill: "#dbeafe"
  style.stroke: "#3b82f6"

  source: "DataBento\nMBP-10 (market-by-price, 10 levels)\nus_hours filter (14:30–21:00 UTC)" {
    shape: step
    style.fill: "#bfdbfe"
  }

  symbols: "6 symbols\nAAPL · MSFT · TSLA\nMETA · AMZN · AVGO\n4 trading days\n2026-02-25 to 2026-03-02" {
    shape: step
    style.fill: "#bfdbfe"
  }

  parquet: "Raw MBP-10 parquet per symbol per day\n~7M tick events · ~40 columns\nbid_px_00..09 · ask_px_00..09\nbid_sz_00..09 · ask_sz_00..09\nbid_ct_00..09 · ask_ct_00..09\naction · ts_event\n\nTraining files: 18  (6 symbols × 3 days: 2026-02-25, -02-26, -02-27)\nVal/test files:  6  (6 symbols × 1 day:  2026-03-02)" {
    shape: cylinder
    style.fill: "#93c5fd"
  }

  source -> symbols -> parquet
}

# ─────────────────────────────────────────────
# Stage 2 – Offline feature research
# ─────────────────────────────────────────────
research: Offline Feature Research {
  style.fill: "#fef9c3"
  style.stroke: "#ca8a04"

  per_symbol: Per-Symbol Scoring (repeat for each of 6 symbols) {
    style.fill: "#fefce8"
    style.stroke: "#a16207"

    fr_split: "Chronological split\ntrain: first train_size rows\nval: next validation_size rows" {
      shape: step
      style.fill: "#fef08a"
    }

    fr_cache: "Feature cache check\n.cache/feature_transformation/\nkey = MD5(path + mtime + sizes + feature_config)" {
      shape: diamond
      style.fill: "#fde68a"
    }

    fr_pipe: "FeaturePipeline.fit(train)\ntransform train + val\nWelford online normalisation\nper-feature z-score · session boundary reset" {
      shape: step
      style.fill: "#fef08a"
    }

    fr_cache_write: "Write to cache\nfr_train_features.parquet\nfr_val_features.parquet\nfr_train_price.parquet\nfr_val_price.parquet" {
      shape: cylinder
      style.fill: "#fde68a"
    }

    fr_price: "Resolve price series\nmid-price = (bid_px_00 + ask_px_00) / 2\n(no close column in LOB data)" {
      shape: step
      style.fill: "#fef08a"
    }

    fr_target: "Build proxy targets per horizon h ∈ [10, 50, 200]\n\nSharpe proxy (default):\n  tick_log_ret = log(price[t] / price[t-1])\n  rolling_vol  = rolling std of tick_log_ret (window=50)\n  forward_ret  = log(price[t+h] / price[t])\n  target       = forward_ret / (rolling_vol + 1e-10)\n\nReturn proxy (alternative):\n  target = log(price[t+h] / price[t])" {
      shape: step
      style.fill: "#fef08a"
    }

    fr_ic: "IC scoring — per feature × per horizon\n\nRolling Spearman rank correlation (window_size=1000)\n  feat_ranked = rolling rank of feature values\n  tgt_ranked  = rolling rank of target values\n  IC_t        = Pearson(feat_ranked_t, tgt_ranked_t)\n\nStats computed on train split:\n  mean_ic          = mean(IC series)\n  ic_std           = std(IC series)\n  ICIR             = mean_ic / ic_std\n  ic_tstat         = mean_ic / (ic_std / √n)\n  ic_positive_ratio = fraction of IC > 0\n\nOut-of-sample check on val split:\n  val_mean_ic      = mean IC on val data" {
      shape: step
      style.fill: "#fef08a"
    }

    fr_best_h: "Best horizon selection per feature\nkeep stats for horizon with highest |ICIR|\nrecord best_horizon\nic_stability = |mean_ic − val_mean_ic|" {
      shape: step
      style.fill: "#fef08a"
    }

    fr_scores_sym: "feature_scores_{symbol}.csv\nfeature · best_horizon · mean_ic\nic_std · ICIR · ic_tstat\nic_positive_ratio · val_mean_ic · ic_stability" {
      shape: document
      style.fill: "#fde68a"
    }

    fr_split -> fr_cache
    fr_cache -> fr_pipe: "miss"
    fr_pipe -> fr_cache_write
    fr_cache_write -> fr_price
    fr_cache -> fr_price: "hit (skip transform)"
    fr_price -> fr_target -> fr_ic -> fr_best_h -> fr_scores_sym
  }

  fr_agg: "Aggregate scores across all 6 symbols\nmean of: mean_ic · ic_std · ICIR · ic_tstat\n         ic_positive_ratio · val_mean_ic · ic_stability\nbest_horizon = mode across symbols\nsort by |ICIR| descending" {
    shape: step
    style.fill: "#fef08a"
  }

  fr_sel: "Greedy conditional IC selection\n\n1. Walk features sorted by |ICIR| descending\n2. Skip if |ICIR| < icir_threshold (default 0.02)\n3. Accept candidate → append to selected\n4. Residualise remaining features against selected:\n     regressor.fit(selected_matrix, remaining_matrix)\n     remaining -= regressor.predict(selected_matrix)\n   (removes shared linear variance so next pick\n    is not a near-duplicate of an already-selected feature)\n5. Repeat until top_k features selected (default 10)" {
    shape: step
    style.fill: "#fef08a"
  }

  fr_outputs: Artifacts {
    style.fill: "#fefce8"
    style.stroke: "#a16207"

    fr_scores_csv: "feature_scores.csv\naggregated rankings · all features" {
      shape: document
      style.fill: "#fde68a"
    }

    fr_corr_csv: "feature_correlations.csv\npairwise Pearson correlation\non pooled val features (capped 20k rows/symbol)" {
      shape: document
      style.fill: "#fde68a"
    }

    fr_yaml: "selected_features.yaml\nreduced feature config\nonly top_k selected features" {
      shape: document
      style.fill: "#fde68a"
    }

    fr_summary: "summary.md\ntop-10 ranked features table\nselected list · experiment config" {
      shape: document
      style.fill: "#fde68a"
    }
  }

  per_symbol -> fr_agg -> fr_sel -> fr_outputs
}

# ─────────────────────────────────────────────
# Stage 3 – Data preparation
# ─────────────────────────────────────────────
prep: Data Preparation {
  style.fill: "#dcfce7"
  style.stroke: "#16a34a"

  dp_prepared_cache: "Prepared-data cache check\ndata/prepared/{experiment}/{train,val,test}_prepared.parquet\n+ _prepared_cache_metadata.json\nKey: config signature (feature_config hash + data source mtimes + env mode)" {
    shape: diamond
    style.fill: "#bbf7d0"
  }

  dp_mode: "Splitting mode\nval_data_paths configured?" {
    shape: diamond
    style.fill: "#bbf7d0"
  }

  # ── Per-day path (production pooled daily scenario) ──────────────────────
  dp_perday: Per-Day Split Mode  (val_data_paths present — production path) {
    style.fill: "#f0fdf4"
    style.stroke: "#15803d"

    pd_group: "Group 18 training parquet files by symbol\n6 symbol groups (AAPL · AMZN · AVGO · META · MSFT · TSLA)\n3 files per symbol (days 2026-02-25, -02-26, -02-27)\nsorted alphabetically by filename prefix" {
      shape: step
      style.fill: "#bbf7d0"
    }

    pd_fit: "Per-symbol pipeline fitting  (6 × fit)\nFor each symbol:\n  concat raw DataFrames for its 3 training days\n  FeaturePipeline.fit(combined)\n    Welford online normalisation\n    session boundary reset at gaps > 1 hour\n  discard combined frame + gc.collect()" {
      shape: step
      style.fill: "#bbf7d0"
    }

    pd_train_transform: "Transform 18 training files  (one per day-symbol)\nFor each file i ∈ [0..17]:\n  raw_df = load_parquet(path_i).dropna()\n  features = pipeline[symbol_i].transform(raw_df)\n  merged = concat(raw_df, features)\n  HFT: derive close = (bid_px_00 + ask_px_00) / 2\n  HFT: deduplicate timestamps (1µs min gap)\n  save_symbol_memmap(merged, memmap_dir, prefix=i)\n    → {i}_train_data.npy · {i}_train_index.npy · {i}_columns.json\n  free merged + gc.collect()" {
      shape: step
      style.fill: "#bbf7d0"
    }

    pd_val_transform: "Transform 6 val files  (one per symbol, day 2026-03-02)\nFor each val_path_j  (j ∈ [0..5]):\n  raw_val = load_parquet(val_path_j).dropna()\n  features = pipeline[symbol_j].transform(raw_val)\n  merged = concat(raw_val, features)\n  HFT: derive close · deduplicate timestamps\n  split at midpoint (50/50):\n    val_j  = merged[:mid]  → saved to tmp parquet\n    test_j = merged[mid:]  → saved to tmp parquet\n  free merged + gc.collect()" {
      shape: step
      style.fill: "#bbf7d0"
    }

    pd_assemble: "Assemble val / test DataFrames\nval_df  = pd.concat(val_j  for j in 0..5)\ntest_df = pd.concat(test_j for j in 0..5)\nRe-deduplicate timestamps on concatenated frames\n  (fix cross-symbol timestamp collisions after concat)\ntrain_df = first_train_df  (file 0, reference only —\n  actual training lives in the 18 memmaps)" {
      shape: step
      style.fill: "#bbf7d0"
    }

    pd_memmaps: "18 memmap files (one per training day-symbol pair)\n{i}_train_data.npy   (n_rows × n_cols, float32)\n{i}_train_index.npy  (nanosecond timestamps)\n{i}_columns.json     (column names)" {
      shape: cylinder
      style.fill: "#86efac"
    }

    pd_group -> pd_fit -> pd_train_transform -> pd_val_transform -> pd_assemble
    pd_train_transform -> pd_memmaps
  }

  # ── Chronological path (single symbol or pooled without val_data_paths) ──
  dp_loop: Per-Symbol Chronological Mode  (no val_data_paths, repeat for each symbol) {
    style.fill: "#f0fdf4"
    style.stroke: "#15803d"

    dp_cache_chk: "Feature cache check\n.cache/feature_transformation/\nkey = MD5(path + mtime + sizes + feature_config)" {
      shape: diamond
      style.fill: "#bbf7d0"
    }

    dp_load: "load_trading_data()\nread parquet · drop NaNs\n~7M rows" {
      shape: step
      style.fill: "#bbf7d0"
    }

    dp_split: "Chronological split (no shuffling)\ntrain:  first train_size rows  (200k)\nval:    next  validation_size  (~3.4M)\ntest:   remainder               (~3.4M)" {
      shape: step
      style.fill: "#bbf7d0"
    }

    dp_fit: "FeaturePipeline.fit(train_df_raw)\ncompute normalisation stats on train ONLY\nWelford online algorithm\nresets at session gaps > 1 hour" {
      shape: step
      style.fill: "#bbf7d0"
    }

    dp_transform: "Transform all three splits\ntrain_features = pipeline.transform(train_df_raw)\nval_features   = pipeline.transform(val_df_raw)\ntest_features  = pipeline.transform(test_df_raw)" {
      shape: step
      style.fill: "#bbf7d0"
    }

    dp_hft: "HFT post-processing\nensure_close_column_for_hft()\n  close = (bid_px_00 + ask_px_00) / 2\nensure_unique_index_for_hft_tradingenv()\n  deduplicate timestamps with 1µs gap" {
      shape: step
      style.fill: "#bbf7d0"
    }

    dp_cache_write: "Write parquet cache\n.cache/feature_transformation/{key}/\ntrain.parquet · val.parquet · test.parquet" {
      shape: cylinder
      style.fill: "#86efac"
    }

    dp_memmap: "save_symbol_memmap(train_df)\nwrite float32 binary array to disk\n{i}_train_data.npy   (n_rows × n_cols)\n{i}_train_index.npy  (nanosecond timestamps)\n{i}_columns.json     (column names)" {
      shape: cylinder
      style.fill: "#86efac"
    }

    dp_cache_chk -> dp_load: "miss"
    dp_cache_chk -> dp_hft: "hit (skip load + transform)"
    dp_load -> dp_split -> dp_fit -> dp_transform -> dp_hft
    dp_hft -> dp_cache_write
    dp_hft -> dp_memmap
  }

  dp_validate: "validate_prepared_data()\ncheck: train / val / test non-empty\ncheck: close column present\ncheck: feature_* columns present\ncheck: no NaN or Inf in train · val · test splits" {
    shape: step
    style.fill: "#bbf7d0"
  }

  dp_prepared: "PreparedDataset\ntrain_df · val_df · test_df\nfeature_columns · price_column · raw_columns\nmemmap_train_paths  (18 MemmapPaths in per-day mode)" {
    shape: step
    style.fill: "#86efac"
  }

  dp_prepared_cache -> dp_mode: "miss"
  dp_prepared_cache -> dp_prepared: "hit — load parquets from cache, skip all processing"
  dp_mode -> dp_perday: "yes — production pooled daily"
  dp_mode -> dp_loop: "no — single symbol or pooled (chronological)"
  dp_perday.pd_assemble -> dp_validate
  dp_loop -> dp_validate
  dp_validate -> dp_prepared
}

# ─────────────────────────────────────────────
# Stage 4 – RL Training
# ─────────────────────────────────────────────
train: RL Training {
  style.fill: "#fee2e2"
  style.stroke: "#dc2626"

  shared_env: Shared Environment + Reward {
    style.fill: "#fff1f2"
    style.stroke: "#b91c1c"

    env: "StreamingTradingEnvXY  (episode reset)\nPick next file from shuffled deck of 18 memmaps\n  (6 symbols × 3 training days; deck reshuffled each cycle)\nPick random start ∈ [0, n_rows − episode_length]\nLoad 50k-row window from memmap\nBuild fresh inner tradingenv.TradingEnv on each reset\n  action_space: BoxPortfolio [−1, 1]\n  observation: CustomFeature (26 static + 1 runtime position)\nobs_clip = 5.0: clamp normalized observations to [−5, 5]\n  (caps session-open normalization spikes)\n→ ~40 episodes across 2M training steps" {
      shape: step
      style.fill: "#fecaca"
    }

    reward: "Differential Sharpe Ratio reward  (per step)\n\nR_t = log return of portfolio value  (NLV path, includes fees)\n\nEMA updates (η = 0.01):\n  A_t = (1−η)·A_{t−1} + η·R_t        (mean)\n  B_t = (1−η)·B_{t−1} + η·R_t²       (2nd moment)\n\nReward:\n  ΔA_t = R_t − A_{t−1}\n  ΔB_t = R_t² − B_{t−1}\n  D_t  = (B_{t−1}·ΔA_t − A_{t−1}·ΔB_t/2)\n          / (B_{t−1} − A_{t−1}²)^(3/2) + ε\n\nclip_rewards = True: clamp D_t to [−10, 10]  (prevents gradient explosion)\n  configurable via clip_reward in DifferentialSharpeRatioAnyTrading\n\nReset A_t, B_t, prev_nlv to zero at each episode start" {
      shape: step
      style.fill: "#fecaca"
    }

    collector: "SyncDataCollector\ncollect frames_per_batch = 200 transitions per update\n\nTD3 / DDPG:  init_rand_steps = 1000 fully random warmup\n             (RandomPolicy used until buffer has enough data)\nPPO:         init_rand_steps = 0  (stochastic sampling is inherent)" {
      shape: step
      style.fill: "#fecaca"
    }

    env -> reward -> collector
  }

  td3: TD3  (Twin Delayed Deep Deterministic Policy Gradient) {
    style.fill: "#fff1f2"
    style.stroke: "#991b1b"

    td3_net: "Networks\nActor (deterministic):\n  MLP [n_obs → 128 → 64 → n_act] + ReLU + Tanh\n  output: continuous portfolio weight ∈ [−1, 1]\n\nTwin Critics (clipped double Q):\n  2 × MLP [n_obs + n_act → 128 → 64 → 1] + ReLU\n  input: concat(observation, action)\n\nTarget Networks (soft-copied):\n  actor_target · Q1_target · Q2_target\n  τ = 0.001" {
      shape: step
      style.fill: "#fecaca"
    }

    td3_explore: "Exploration\nAdditiveGaussianModule\nσ = 0.1 (exploration_noise_std) added to deterministic action\nclipped to action spec bounds [−1, 1]" {
      shape: step
      style.fill: "#fecaca"
    }

    td3_buffer: "Replay Buffer  (off-policy)\nLazyTensorStorage · capacity = 100k transitions\nsampling: uniform random\nsample_size = 128 per gradient step" {
      shape: queue
      style.fill: "#fca5a5"
    }

    td3_update: "Update  (optim_steps_per_batch = 5 per collect)\n\nCritic loss  (SmoothL1):\n  ã = actor_target(s') + clip(N(0, σ=0.2), ±0.3)\n  y = r + γ · min(Q1_tgt(s',ã), Q2_tgt(s',ã))  γ=0.995\n  L = SmoothL1(Q1(s,a)−y) + SmoothL1(Q2(s,a)−y)\n\nActor loss  (every policy_delay=2 critic steps):\n  L = −mean(Q1(s, actor(s)))\n\nSoft target update  (every actor update step):\n  θ_tgt ← τ·θ + (1−τ)·θ_tgt  τ=0.001" {
      shape: step
      style.fill: "#fecaca"
    }

    td3_net -> td3_explore -> td3_buffer -> td3_update
  }

  ddpg: DDPG  (Deep Deterministic Policy Gradient) {
    style.fill: "#fff1f2"
    style.stroke: "#991b1b"

    ddpg_net: "Networks\nActor (deterministic):\n  MLP [n_obs → 128 → 64 → n_act] + ReLU + Tanh\n  output: continuous portfolio weight ∈ [−1, 1]\n\nSingle Critic  (standard Q):\n  MLP [n_obs + n_act → 128 → 64 → 1] + ReLU\n  input: concat(observation, action)\n\nTarget Networks (soft-copied):\n  actor_target · Q_target\n  τ = 0.001" {
      shape: step
      style.fill: "#fecaca"
    }

    ddpg_explore: "Exploration\nAdditiveGaussianModule\nσ = 0.1 (exploration_noise_std) added to deterministic action\nclipped to action spec bounds [−1, 1]" {
      shape: step
      style.fill: "#fecaca"
    }

    ddpg_buffer: "Replay Buffer  (off-policy)\nLazyTensorStorage · capacity = 100k transitions\nsampling: uniform random\nsample_size = 128 per gradient step" {
      shape: queue
      style.fill: "#fca5a5"
    }

    ddpg_update: "Update  (optim_steps_per_batch = 5 per collect)\n\nCritic loss  (SmoothL1):\n  y = r + γ · Q_target(s', actor_target(s'))  γ=0.995\n  L = SmoothL1(Q(s,a) − y)\n\nActor loss  (every step — no policy delay):\n  L = −mean(Q(s, actor(s)))\n\nSoft target update  (every step):\n  θ_tgt ← τ·θ + (1−τ)·θ_tgt  τ=0.001\n\nNote: no target policy smoothing (noise_clip is TD3-only)" {
      shape: step
      style.fill: "#fecaca"
    }

    ddpg_net -> ddpg_explore -> ddpg_buffer -> ddpg_update
  }

  ppo: PPO  (Proximal Policy Optimisation) {
    style.fill: "#fff1f2"
    style.stroke: "#991b1b"

    ppo_net: "Networks\nActor (stochastic):\n  Discrete: MLP [n_obs → 128 → 64 → n_act] → softmax\n    → OneHotCategorical distribution\n    → samples discrete action + log_prob\n  Continuous: MLP [n_obs → 64 → 32 → n_act×2] + Tanh\n    → NormalParamExtractor → loc, scale\n    → TanhNormal distribution\n\nCritic  (state value V(s), no action input):\n  MLP [n_obs → 128 → 64 → 1]\n  output: V(s)  (not Q(s,a))\n\nNo target networks" {
      shape: step
      style.fill: "#fecaca"
    }

    ppo_explore: "Exploration\nStochastic sampling from\nactor distribution (inherent)\nno separate noise module" {
      shape: step
      style.fill: "#fecaca"
    }

    ppo_advantage: "Advantage estimation  (on full batch before shuffle)\nGAE via TorchRL ValueEstimator\ncomputed on ordered rollout\nbefore minibatch sampling\n(shuffling would break temporal structure)" {
      shape: step
      style.fill: "#fecaca"
    }

    ppo_update: "Update  (ppo_epochs=4 passes over fresh batch)\nOn-policy: fresh batch only — no replay buffer\nnormalize_advantage = True\n\nClipPPOLoss:\n  r_t = π(a|s) / π_old(a|s)  (probability ratio)\n  loss_objective = −min(r_t·A_t, clip(r_t, 1±ε)·A_t)  ε=0.2\n  loss_critic    = L2(V(s) − V_target)\n  loss_entropy   = −H[π]  (entropy bonus = 0.01)\n\n  total = loss_objective\n        + vf_coef × loss_critic   (vf_coef = 0.5)\n        + entropy_bonus × loss_entropy" {
      shape: step
      style.fill: "#fecaca"
    }

    ppo_net -> ppo_explore -> ppo_advantage -> ppo_update
  }

  ckpt: "Checkpoint  (every checkpoint_interval = 100k steps)\nactor weights · critic weights\ntarget network weights (TD3/DDPG only)\noptimizer states\ntotal_count · total_episodes · logs\nmlflow run id / name / experiment id / uri\nreplay buffer dump (optional, TD3/DDPG only)\nsaved to logs/{experiment}/" {
    shape: document
    style.fill: "#fca5a5"
  }

  resume: "Checkpoint Resumption  (optional)\n--checkpoint-path flag → load saved state\nrestore actor / critic / optimizer / buffer\nresume MLflow run (same run_id)\nadditional_steps override for extended training" {
    shape: step
    style.fill: "#fecaca"
  }

  periodic_eval: "Periodic evaluation  (every temp_eval_interval = 100k steps)\ndedicated _eval_env  (separate from training env; warns if reusing training env)\ndeterministic rollout on train-split window\neval_steps = int(val_len × eval_fraction)  — data-size-relative horizon\n  eval_fraction overrides fixed eval_steps when set\nlog episode reward · portfolio return\n→ temp MLflow metric (not final eval)" {
    shape: step
    style.fill: "#fecaca"
  }

  periodic_expl: "Periodic explainability  (every temp_explainability_interval = 100k steps)\nPermutation importance on train-split window\nn_steps = 500 rollout\nrank feature importance by reward drop\n→ temp artifact logged to MLflow" {
    shape: step
    style.fill: "#fecaca"
  }

  train_mlflow: MLflow — logged during training {
    style.fill: "#fff1f2"
    style.stroke: "#b91c1c"

    train_params: "Parameters  (logged once at run start)\nexperiment_name · seed\ndata: train_size · timeframe · symbols\nenv: name · positions · trading_fees · reward_type\nnetwork: actor_hidden_dims · value_hidden_dims\ntraining: algorithm · lr · max_steps · buffer_size\n          batch_size · gamma · tau · policy_delay (TD3)\n          policy_noise · noise_clip (TD3)\n          clip_epsilon · entropy_bonus (PPO)" {
      shape: document
      style.fill: "#fecaca"
    }

    train_step_metrics: "Step metrics  (every log_interval = 100 steps)\nactor_loss · value_loss\nloss_entropy (PPO only)\ntotal_steps_trained · avg_position_changes" {
      shape: document
      style.fill: "#fecaca"
    }

    train_episode_metrics: "Episode metrics  (every episode end)\nepisode_reward · episode_portfolio_valuation\nepisode_position_changes\nepisode_position_change_ratio\nepisode_sum_position · episode_exploration_ratio" {
      shape: document
      style.fill: "#fecaca"
    }

    train_config_artifact: "Config artifacts  (logged once)\nscenario YAML file\nparameter_faq.md documentation" {
      shape: document
      style.fill: "#fecaca"
    }
  }

  shared_env -> td3
  shared_env -> ddpg
  shared_env -> ppo
  td3.td3_update -> ckpt
  ddpg.ddpg_update -> ckpt
  ppo.ppo_update -> ckpt
  td3.td3_update -> periodic_eval
  ddpg.ddpg_update -> periodic_eval
  ppo.ppo_update -> periodic_eval
  td3.td3_update -> periodic_expl
  ddpg.ddpg_update -> periodic_expl
  ppo.ppo_update -> periodic_expl
  td3.td3_update -> train_mlflow
  ddpg.ddpg_update -> train_mlflow
  ppo.ppo_update -> train_mlflow
  periodic_eval -> shared_env.collector: "continue training"
  resume -> td3.td3_net: "restore weights + optimizer"
  resume -> ddpg.ddpg_net: "restore weights + optimizer"
  resume -> ppo.ppo_net: "restore weights + optimizer"
}

# ─────────────────────────────────────────────
# Stage 5 – Evaluation
# ─────────────────────────────────────────────
eval: Post-Training Evaluation {
  style.fill: "#f3e8ff"
  style.stroke: "#9333ea"

  rollout: "Deterministic rollout  (no exploration noise)\nfull val split  (eval_fraction = 0.2 of total)\nfull test split (eval_fraction = 0.2 of total)\nactor in deterministic / MODE interaction type" {
    shape: step
    style.fill: "#e9d5ff"
  }

  metrics: "Performance metrics  (per split)\nSharpe ratio      · Sortino ratio\nTotal return       · Annualised return\nMax drawdown       · Avg drawdown\nMax drawdown duration · Recovery time\nWin rate (hit rate)\nPosition change ratio" {
    shape: step
    style.fill: "#e9d5ff"
  }

  benchmarks: "Benchmark strategies  (BenchmarkEngine.build())\nBenchmarkSpec: pure callable  compute_returns(max_steps) → np.ndarray\n  closes over price / volume series — no env coupling\nBenchmarkEngine resolves price column + volume source from market_data\nBuilt specs: Buy-and-hold · Short-and-hold · TWAP · VWAP\nRandom policy: compute_random_baseline_returns(env, ...)  (env-side only)\n  env coupling isolated to pipeline/evaluation.py\n(same time period, same starting capital)" {
    shape: step
    style.fill: "#e9d5ff"
  }

  stats: "Statistical significance tests\nvs each benchmark:\n  t-test (two-sample, returns)\n  Mann-Whitney U test\n  Sharpe bootstrap  (n=10k samples)\n  Sortino bootstrap (n=10k samples)\n  Permutation test  (n=10k permutations)\nconfidence level = 0.95\nreports p-value · test statistic · conclusion" {
    shape: step
    style.fill: "#e9d5ff"
  }

  expl: "Explainability  (primary split)\n\nPermutation feature importance (Captum FeaturePermutation):\n  for each feature:\n    shuffle feature values in observation\n    measure drop in cumulative reward vs baseline\n    importance = reward_original − reward_shuffled\n  n_steps = 500\n  output: ranked feature importance bar chart\n\nIntegrated Gradients (Captum IntegratedGradients):\n  ActorCaptumProxy wraps TorchRL actor for Captum\n  compute IG(x) = (x − baseline) × ∫ ∂actor/∂x dα  (n_steps=500)\n  baseline = zero tensor\n  output: signed feature attribution scores\n  (DDPG and PPO configs only)" {
    shape: step
    style.fill: "#e9d5ff"
  }

  eval_artifacts: MLflow — artifacts logged after training {
    style.fill: "#faf5ff"
    style.stroke: "#7e22ce"

    final_metrics: "Final summary metrics\nfinal_reward · training_steps\navg_actor_loss · episode_avg_reward\nepisode_portfolio_valuation\navg_position_change_ratio\ntotal_position_changes" {
      shape: document
      style.fill: "#e9d5ff"
    }

    eval_metrics_artifact: "Evaluation metrics  (per split: train · val · test)\nevaluation_metrics/{split}/*.json\nall performance metrics as JSON\n+ mlflow scalar metrics prefixed eval_{split}_*" {
      shape: document
      style.fill: "#e9d5ff"
    }

    eval_plots: "Evaluation plots  (per split)\nevaluation_plots/\n  reward_comparison.png   (agent vs benchmarks)\n  actions_plot.png        (portfolio weights over time)\n  actual_returns_plot.png (realised P&L)\n  merged_plot.png         (reward + actions combined)" {
      shape: document
      style.fill: "#e9d5ff"
    }

    stat_artifacts: "Statistical test artifacts  (per split)\nstatistical_tests/{split}/*.json  (full results)\nstatistical_tests/{split}/*.csv   (benchmark table)\nresearch_artifacts/statistical_tests/*.json\n  (compact summary: p-values · effect sizes · significance)" {
      shape: document
      style.fill: "#e9d5ff"
    }

    expl_artifacts: "Explainability artifacts  (primary split)\nexplainability/\n  explainability_permutation.png  (importance bar chart)\n  importance_permutation.csv      (scores per feature)\n  explainability_integrated_gradients.png  (attribution chart)\n  importance_integrated_gradients.csv      (signed scores)" {
      shape: document
      style.fill: "#e9d5ff"
    }

    position_data: "Position / portfolio weight data\nposition_data/*.json   (last 100 positions per episode)\nportfolio_weights_data/*.json" {
      shape: document
      style.fill: "#e9d5ff"
    }
  }

  rollout -> metrics -> benchmarks -> stats -> eval_artifacts
  rollout -> expl -> eval_artifacts
}

