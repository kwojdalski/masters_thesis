direction: down

# ─────────────────────────────────────────────
# Stage 1 – Data Acquisition
# ─────────────────────────────────────────────
acquire: Data Acquisition {
  style.fill: "#dbeafe"
  style.stroke: "#3b82f6"

  source: "DataBento\nMBP-10 (market-by-price, 10 levels)\nus_hours filter (14:30–21:00 UTC)" {
    shape: step
    style.fill: "#bfdbfe"
  }

  symbols: "6 symbols\nAAPL · MSFT · TSLA\nMETA · AMZN · AVGO\n4 trading days\n2026-02-25 to 2026-03-03" {
    shape: step
    style.fill: "#bfdbfe"
  }

  parquet: "Raw MBP-10 parquet per symbol\n~7M tick events · ~40 columns\nbid_px_00..09 · ask_px_00..09\nbid_sz_00..09 · ask_sz_00..09\nbid_ct_00..09 · ask_ct_00..09\naction · ts_event" {
    shape: cylinder
    style.fill: "#93c5fd"
  }

  source -> symbols -> parquet
}

# ─────────────────────────────────────────────
# Stage 2 – Offline feature research
# ─────────────────────────────────────────────
research: Offline Feature Research {
  style.fill: "#fef9c3"
  style.stroke: "#ca8a04"

  per_symbol: Per-Symbol Scoring (repeat for each of 6 symbols) {
    style.fill: "#fefce8"
    style.stroke: "#a16207"

    fr_split: "Chronological split\ntrain: first train_size rows\nval: next validation_size rows" {
      shape: step
      style.fill: "#fef08a"
    }

    fr_cache: "Feature cache check\n.cache/feature_transformation/\nkey = MD5(path + mtime + sizes + feature_config)" {
      shape: diamond
      style.fill: "#fde68a"
    }

    fr_pipe: "FeaturePipeline.fit(train)\ntransform train + val\nWelford online normalisation\nper-feature z-score · session boundary reset" {
      shape: step
      style.fill: "#fef08a"
    }

    fr_cache_write: "Write to cache\nfr_train_features.parquet\nfr_val_features.parquet\nfr_train_price.parquet\nfr_val_price.parquet" {
      shape: cylinder
      style.fill: "#fde68a"
    }

    fr_price: "Resolve price series\nmid-price = (bid_px_00 + ask_px_00) / 2\n(no close column in LOB data)" {
      shape: step
      style.fill: "#fef08a"
    }

    fr_target: "Build proxy targets per horizon h ∈ [10, 50, 200]\n\nSharpe proxy (default):\n  tick_log_ret = log(price[t] / price[t-1])\n  rolling_vol  = rolling std of tick_log_ret (window=50)\n  forward_ret  = log(price[t+h] / price[t])\n  target       = forward_ret / (rolling_vol + 1e-10)\n\nReturn proxy (alternative):\n  target = log(price[t+h] / price[t])" {
      shape: step
      style.fill: "#fef08a"
    }

    fr_ic: "IC scoring — per feature × per horizon\n\nRolling Spearman rank correlation (window_size=1000)\n  feat_ranked = rolling rank of feature values\n  tgt_ranked  = rolling rank of target values\n  IC_t        = Pearson(feat_ranked_t, tgt_ranked_t)\n\nStats computed on train split:\n  mean_ic          = mean(IC series)\n  ic_std           = std(IC series)\n  ICIR             = mean_ic / ic_std\n  ic_tstat         = mean_ic / (ic_std / √n)\n  ic_positive_ratio = fraction of IC > 0\n\nOut-of-sample check on val split:\n  val_mean_ic      = mean IC on val data" {
      shape: step
      style.fill: "#fef08a"
    }

    fr_best_h: "Best horizon selection per feature\nkeep stats for horizon with highest |ICIR|\nrecord best_horizon\nic_stability = |mean_ic − val_mean_ic|" {
      shape: step
      style.fill: "#fef08a"
    }

    fr_scores_sym: "feature_scores_{symbol}.csv\nfeature · best_horizon · mean_ic\nic_std · ICIR · ic_tstat\nic_positive_ratio · val_mean_ic · ic_stability" {
      shape: document
      style.fill: "#fde68a"
    }

    fr_split -> fr_cache
    fr_cache -> fr_pipe: "miss"
    fr_pipe -> fr_cache_write
    fr_cache_write -> fr_price
    fr_cache -> fr_price: "hit (skip transform)"
    fr_price -> fr_target -> fr_ic -> fr_best_h -> fr_scores_sym
  }

  fr_agg: "Aggregate scores across all 6 symbols\nmean of: mean_ic · ic_std · ICIR · ic_tstat\n         ic_positive_ratio · val_mean_ic · ic_stability\nbest_horizon = mode across symbols\nsort by |ICIR| descending" {
    shape: step
    style.fill: "#fef08a"
  }

  fr_sel: "Greedy conditional IC selection\n\n1. Walk features sorted by |ICIR| descending\n2. Skip if |ICIR| < icir_threshold (default 0.02)\n3. Accept candidate → append to selected\n4. Residualise remaining features against selected:\n     regressor.fit(selected_matrix, remaining_matrix)\n     remaining -= regressor.predict(selected_matrix)\n   (removes shared linear variance so next pick\n    is not a near-duplicate of an already-selected feature)\n5. Repeat until top_k features selected (default 10)" {
    shape: step
    style.fill: "#fef08a"
  }

  fr_outputs: Artifacts {
    style.fill: "#fefce8"
    style.stroke: "#a16207"

    fr_scores_csv: "feature_scores.csv\naggregated rankings · all features" {
      shape: document
      style.fill: "#fde68a"
    }

    fr_corr_csv: "feature_correlations.csv\npairwise Pearson correlation\non pooled val features (capped 20k rows/symbol)" {
      shape: document
      style.fill: "#fde68a"
    }

    fr_yaml: "selected_features.yaml\nreduced feature config\nonly top_k selected features" {
      shape: document
      style.fill: "#fde68a"
    }

    fr_summary: "summary.md\ntop-10 ranked features table\nselected list · experiment config" {
      shape: document
      style.fill: "#fde68a"
    }
  }

  per_symbol -> fr_agg -> fr_sel -> fr_outputs
}

# ─────────────────────────────────────────────
# Stage 3 – Data preparation
# ─────────────────────────────────────────────
prep: Data Preparation {
  style.fill: "#dcfce7"
  style.stroke: "#16a34a"

  dp_loop: Per-Symbol Processing (repeat for each of 6 symbols) {
    style.fill: "#f0fdf4"
    style.stroke: "#15803d"

    dp_cache_chk: "Feature cache check\n.cache/feature_transformation/\nkey = MD5(path + mtime + sizes + feature_config)" {
      shape: diamond
      style.fill: "#bbf7d0"
    }

    dp_load: "load_trading_data()\nread parquet · drop NaNs\n~7M rows" {
      shape: step
      style.fill: "#bbf7d0"
    }

    dp_split: "Chronological split (no shuffling)\ntrain:  first train_size rows  (200k)\nval:    next  validation_size  (~3.4M)\ntest:   remainder               (~3.4M)" {
      shape: step
      style.fill: "#bbf7d0"
    }

    dp_fit: "FeaturePipeline.fit(train_df_raw)\ncompute normalisation stats on train ONLY\nWelford online algorithm\nresets at session gaps > 1 hour" {
      shape: step
      style.fill: "#bbf7d0"
    }

    dp_transform: "Transform all three splits\ntrain_features = pipeline.transform(train_df_raw)\nval_features   = pipeline.transform(val_df_raw)\ntest_features  = pipeline.transform(test_df_raw)" {
      shape: step
      style.fill: "#bbf7d0"
    }

    dp_hft: "HFT post-processing\nensure_close_column_for_hft()\n  close = (bid_px_00 + ask_px_00) / 2\nensure_unique_index_for_hft_tradingenv()\n  deduplicate timestamps with 1µs gap" {
      shape: step
      style.fill: "#bbf7d0"
    }

    dp_cache_write: "Write parquet cache\n.cache/feature_transformation/{key}/\ntrain.parquet · val.parquet · test.parquet" {
      shape: cylinder
      style.fill: "#86efac"
    }

    dp_memmap: "save_symbol_memmap(train_df)\nwrite float32 binary array to disk\n{i}_train_data.npy   (n_rows × n_cols)\n{i}_train_index.npy  (nanosecond timestamps)\n{i}_columns.json     (column names)" {
      shape: cylinder
      style.fill: "#86efac"
    }

    dp_cache_chk -> dp_load: "miss"
    dp_cache_chk -> dp_hft: "hit (skip load + transform)"
    dp_load -> dp_split -> dp_fit -> dp_transform -> dp_hft
    dp_hft -> dp_cache_write
    dp_hft -> dp_memmap
  }

  dp_concat: "Concatenate splits across symbols\ntrain_df = first symbol only (streaming mode)\nval_df   = concat all 6 val splits\ntest_df  = concat all 6 test splits\nvalidate_prepared_data()" {
    shape: step
    style.fill: "#bbf7d0"
  }

  dp_prepared: "PreparedDataset\ntrain_df · val_df · test_df\nfeature_columns · price_column\nmemmap_train_paths (6 MemmapPaths)" {
    shape: step
    style.fill: "#86efac"
  }

  dp_loop -> dp_concat -> dp_prepared
}

# ─────────────────────────────────────────────
# Stage 4 – RL Training
# ─────────────────────────────────────────────
train: RL Training {
  style.fill: "#fee2e2"
  style.stroke: "#dc2626"

  networks: Network Architecture {
    style.fill: "#fff1f2"
    style.stroke: "#b91c1c"

    actor_net: "Actor  (deterministic policy)\nMLP: [n_obs → 128 → 64 → n_act]\nReLU activations · Tanh output\nscaled to action bounds [-1, 1]\ncontinuous portfolio weight" {
      shape: step
      style.fill: "#fecaca"
    }

    critic_net: "Twin Critics  (clipped double Q)\n2 × ValueOperator\nMLP: [n_obs + n_act → 128 → 64 → 1]\nReLU activations\ninput = concat(observation, action)" {
      shape: step
      style.fill: "#fecaca"
    }

    target_nets: "Target Networks  (soft-copied)\nactor_target   ← τ·actor   + (1−τ)·actor_target\ncritic_target  ← τ·critic  + (1−τ)·critic_target\nτ = 0.001" {
      shape: step
      style.fill: "#fecaca"
    }
  }

  env: "StreamingTradingEnvXY  (episode reset)\nShuffle symbol deck → pick next symbol\nPick random start ∈ [0, train_size − episode_length]\nLoad 50k-row window from memmap\nBuild inner TradingEnv with DSR reward\n→ ~40 episodes total across 2M training steps" {
    shape: step
    style.fill: "#fecaca"
  }

  reward: "Differential Sharpe Ratio reward  (per step)\n\nR_t = log return of portfolio value\n\nEMA updates (η = 0.01):\n  A_t = (1−η)·A_{t−1} + η·R_t        (mean)\n  B_t = (1−η)·B_{t−1} + η·R_t²       (2nd moment)\n\nReward:\n  ΔA_t = R_t − A_{t−1}\n  ΔB_t = R_t² − B_{t−1}\n  D_t  = (B_{t−1}·ΔA_t − A_{t−1}·ΔB_t/2)\n          / (B_{t−1} − A_{t−1}²)^(3/2) + ε" {
    shape: step
    style.fill: "#fecaca"
  }

  collector: "SyncDataCollector\ncollect frames_per_batch = 200 transitions\nexploration: Gaussian noise σ = 0.1\nfirst init_rand_steps = 1000 are random" {
    shape: step
    style.fill: "#fecaca"
  }

  buffer: "Replay Buffer\nLazyTensorStorage\ncapacity = 100k transitions\nsampling: uniform random" {
    shape: queue
    style.fill: "#fca5a5"
  }

  update: TD3 Update (optim_steps_per_batch = 5 times per collect) {
    style.fill: "#fff1f2"
    style.stroke: "#b91c1c"

    sample: "Sample mini-batch\nbatch_size = 128 transitions\nfrom replay buffer" {
      shape: step
      style.fill: "#fecaca"
    }

    critic_loss: "Critic loss  (smooth L1)\nTarget action:\n  ã = actor_target(s') + clip(N(0, σ=0.2), ±0.3)\nTarget Q:\n  y = r + γ · min(Q1_target(s',ã), Q2_target(s',ã))\n  γ = 0.995\nLoss:\n  L = SmoothL1(Q1(s,a) − y) + SmoothL1(Q2(s,a) − y)" {
      shape: step
      style.fill: "#fecaca"
    }

    actor_loss: "Actor loss  (every policy_delay = 2 critic steps)\n  L = −mean(Q1(s, actor(s)))" {
      shape: step
      style.fill: "#fecaca"
    }

    soft_update: "Soft target update\nactor_target  ← τ·actor  + (1−τ)·actor_target\ncritic_target ← τ·critic + (1−τ)·critic_target\nτ = 0.001" {
      shape: step
      style.fill: "#fecaca"
    }

    sample -> critic_loss -> actor_loss -> soft_update
  }

  ckpt: "Checkpoint  (every 100k steps)\nactor weights · twin critic weights\ntarget network weights\noptimizer states (actor + critic)\ntotal_count · total_episodes · logs\nmlflow run id / name / uri\nreplay buffer dump (optional)\nsaved to logs/{experiment}/" {
    shape: document
    style.fill: "#fca5a5"
  }

  periodic_eval: "Periodic evaluation  (every eval_interval steps)\ndeterministic rollout on train-split window\nlog episode reward · portfolio return\nmarket return benchmark" {
    shape: step
    style.fill: "#fecaca"
  }

  train_mlflow: MLflow — logged during training {
    style.fill: "#fff1f2"
    style.stroke: "#b91c1c"

    train_params: "Parameters  (logged once at run start)\nexperiment_name · seed\ndata: train_size · timeframe · symbols\nenv: name · positions · trading_fees · reward_type\nnetwork: actor_hidden_dims · value_hidden_dims\ntraining: algorithm · lr · max_steps · buffer_size\n          batch_size · gamma · tau · policy_delay\n          policy_noise · noise_clip · exploration_noise_std" {
      shape: document
      style.fill: "#fecaca"
    }

    train_step_metrics: "Step metrics  (every log_interval steps)\nactor_loss · value_loss\ntotal_steps_trained\navg_position_changes" {
      shape: document
      style.fill: "#fecaca"
    }

    train_episode_metrics: "Episode metrics  (every episode end)\nepisode_reward · episode_portfolio_valuation\nepisode_position_changes\nepisode_position_change_ratio\nepisode_sum_position · episode_exploration_ratio" {
      shape: document
      style.fill: "#fecaca"
    }

    train_config_artifact: "Config artifacts  (logged once)\nscenario YAML file\nparameter_faq.md documentation" {
      shape: document
      style.fill: "#fecaca"
    }
  }

  env -> reward -> collector -> buffer -> update
  update -> soft_update: "" {style.opacity: 0}
  update -> ckpt
  update -> periodic_eval
  update -> train_mlflow
  periodic_eval -> collector: "continue training"
}

# ─────────────────────────────────────────────
# Stage 5 – Evaluation
# ─────────────────────────────────────────────
eval: Post-Training Evaluation {
  style.fill: "#f3e8ff"
  style.stroke: "#9333ea"

  rollout: "Deterministic rollout  (no exploration noise)\nfull val split  (~3.4M ticks, continuous)\nfull test split (~3.4M ticks, continuous)\nactor in deterministic mode" {
    shape: step
    style.fill: "#e9d5ff"
  }

  metrics: "Performance metrics  (per split)\nSharpe ratio      · Sortino ratio\nTotal return       · Annualised return\nMax drawdown       · Avg drawdown\nMax drawdown duration · Recovery time\nWin rate (hit rate)\nPosition change ratio" {
    shape: step
    style.fill: "#e9d5ff"
  }

  benchmarks: "Benchmark strategies\nBuy-and-hold · Short-and-hold\nTWAP · VWAP · Random policy\n(same time period, same starting capital)" {
    shape: step
    style.fill: "#e9d5ff"
  }

  stats: "Statistical significance tests\nvs each benchmark:\n  t-test (two-sample, returns)\n  Mann-Whitney U test\n  Sharpe bootstrap  (n=10k samples)\n  Sortino bootstrap (n=10k samples)\nconfidence level = 0.95\nreports p-value · test statistic · conclusion" {
    shape: step
    style.fill: "#e9d5ff"
  }

  expl: "Explainability\nPermutation feature importance:\n  for each feature:\n    shuffle feature values in observation\n    measure drop in cumulative reward\n    importance = reward_original − reward_shuffled\nn_steps = 500\noutput: ranked feature importance bar chart" {
    shape: step
    style.fill: "#e9d5ff"
  }

  eval_artifacts: MLflow — artifacts logged after training {
    style.fill: "#faf5ff"
    style.stroke: "#7e22ce"

    final_metrics: "Final summary metrics\nfinal_reward · training_steps\navg_actor_loss · episode_avg_reward\nepisode_portfolio_valuation\navg_position_change_ratio\ntotal_position_changes" {
      shape: document
      style.fill: "#e9d5ff"
    }

    eval_metrics_artifact: "Evaluation metrics  (per split: train · val · test)\nevaluation_metrics/{split}/*.json\nall performance metrics as JSON\n+ mlflow scalar metrics prefixed eval_{split}_*" {
      shape: document
      style.fill: "#e9d5ff"
    }

    eval_plots: "Evaluation plots  (per split)\nevaluation_plots/\n  reward_comparison.png   (agent vs benchmarks)\n  actions_plot.png        (portfolio weights over time)\n  actual_returns_plot.png (realised P&L)\n  merged_plot.png         (reward + actions combined)" {
      shape: document
      style.fill: "#e9d5ff"
    }

    stat_artifacts: "Statistical test artifacts  (per split)\nstatistical_tests/{split}/*.json  (full results)\nstatistical_tests/{split}/*.csv   (benchmark table)\nresearch_artifacts/statistical_tests/*.json\n  (compact summary: p-values · effect sizes · significance)" {
      shape: document
      style.fill: "#e9d5ff"
    }

    expl_artifacts: "Explainability artifacts  (primary split)\nexplainability/\n  explainability_permutation.png  (importance bar chart)\n  importance_permutation.csv      (scores per feature)" {
      shape: document
      style.fill: "#e9d5ff"
    }

    position_data: "Position / portfolio weight data\nposition_data/*.json   (last 100 positions per episode)\nportfolio_weights_data/*.json" {
      shape: document
      style.fill: "#e9d5ff"
    }
  }

  rollout -> metrics -> benchmarks -> stats -> eval_artifacts
  rollout -> expl -> eval_artifacts
}

# ─────────────────────────────────────────────
# Cross-stage connections
# ─────────────────────────────────────────────
acquire.parquet -> research.per_symbol: "raw tick data\nper symbol"
acquire.parquet -> prep.dp_loop: "raw tick data\nper symbol"

research.fr_outputs.fr_yaml -> prep.dp_loop.dp_fit: "reduced feature config\n(optional, feeds next run)" {
  style.stroke-dash: 4
  style.stroke: "#ca8a04"
}

prep.dp_prepared -> train.env: "MemmapPaths\n6 symbols"
prep.dp_prepared -> eval.rollout: "val_df + test_df\nconcatenated splits"
train.ckpt -> eval.rollout: "trained actor weights\n(deterministic mode)"
