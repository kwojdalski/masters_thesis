direction: down

# ─────────────────────────────────────────────
# Stage 1 – Raw data
# ─────────────────────────────────────────────
acquire: Data Acquisition {
  style.fill: "#dbeafe"
  style.stroke: "#3b82f6"

  parquet: "Raw MBP-10 parquet\n~7M tick events per symbol\n6 symbols · 4 trading days" {
    shape: cylinder
    style.fill: "#bfdbfe"
  }
}

# ─────────────────────────────────────────────
# Stage 2 – Offline feature research
# ─────────────────────────────────────────────
research: Offline Feature Research {
  style.fill: "#fef9c3"
  style.stroke: "#ca8a04"

  per_symbol: Per-Symbol Scoring (repeat for each symbol) {
    style.fill: "#fefce8"
    style.stroke: "#a16207"

    fr_split: "Chronological split\ntrain: first train_size rows\nval: next validation_size rows" {
      shape: step
      style.fill: "#fef08a"
    }

    fr_cache: "Feature cache check\n.cache/feature_transformation/\nkeyed by file hash + config hash" {
      shape: diamond
      style.fill: "#fde68a"
    }

    fr_pipe: "FeaturePipeline.fit(train)\ntransform train + val\nWelford online normalisation\nper-feature z-score" {
      shape: step
      style.fill: "#fef08a"
    }

    fr_cache_write: "Write cache\ntrain_features.parquet\nval_features.parquet\ntrain_price.parquet\nval_price.parquet" {
      shape: cylinder
      style.fill: "#fde68a"
    }

    fr_price: "Resolve price series\nmid-price = (bid_px_00 + ask_px_00) / 2\n(no close column in LOB data)" {
      shape: step
      style.fill: "#fef08a"
    }

    fr_target: "Build proxy targets per horizon h ∈ [10, 50, 200]\n\nSharpe proxy: forward_ret / (rolling_vol + ε)\n  forward_ret  = log(price[t+h] / price[t])\n  rolling_vol  = rolling std of log returns (window=50)\n\nReturn proxy: log(price[t+h] / price[t])" {
      shape: step
      style.fill: "#fef08a"
    }

    fr_ic: "IC scoring per feature × horizon\n\nRolling Spearman rank correlation\n  window_size = 1000 ticks\n\nComputed on train split:\n  mean_ic  = mean of rolling IC series\n  ic_std   = std of rolling IC series\n  ICIR     = mean_ic / ic_std\n  ic_tstat = mean_ic / (ic_std / √n)\n  ic_positive_ratio = fraction IC > 0\n\nComputed on val split (out-of-sample check):\n  val_mean_ic" {
      shape: step
      style.fill: "#fef08a"
    }

    fr_best_h: "Best horizon selection per feature\nkeep horizon with highest |ICIR|\nrecord best_horizon" {
      shape: step
      style.fill: "#fef08a"
    }

    fr_scores_sym: "feature_scores_{symbol}.csv\nfeature · best_horizon · mean_ic\nic_std · ICIR · ic_tstat\nic_positive_ratio · val_mean_ic\nic_stability" {
      shape: document
      style.fill: "#fde68a"
    }

    fr_split -> fr_cache -> fr_pipe: "cache miss"
    fr_cache -> fr_cache_write: "after transform" {style.stroke-dash: 4}
    fr_cache -> fr_price: "cache hit (skip transform)"
    fr_pipe -> fr_price
    fr_price -> fr_target -> fr_ic -> fr_best_h -> fr_scores_sym
  }

  fr_agg: "Aggregate across all symbols\nmean ICIR per feature\nbest_horizon by mode\nsorted by |ICIR| descending" {
    shape: step
    style.fill: "#fef08a"
  }

  fr_sel: "Greedy conditional IC selection\n\n1. Walk features sorted by |ICIR|\n2. Skip if |ICIR| < icir_threshold (0.02)\n3. Add candidate to selected set\n4. Residualise remaining features against\n   selected via LinearRegression\n   (removes shared linear variance)\n5. Stop when top_k features selected" {
    shape: step
    style.fill: "#fef08a"
  }

  fr_outputs: Artifacts {
    style.fill: "#fefce8"
    style.stroke: "#a16207"

    fr_scores_csv: "feature_scores.csv\naggregated rankings\nall features" {
      shape: document
      style.fill: "#fde68a"
    }

    fr_corr_csv: "feature_correlations.csv\npairwise Pearson correlation\non pooled val features" {
      shape: document
      style.fill: "#fde68a"
    }

    fr_yaml: "selected_features.yaml\nreduced feature config\nonly selected features" {
      shape: document
      style.fill: "#fde68a"
    }

    fr_summary: "summary.md\ntop-10 ranked features\nselected list · config params" {
      shape: document
      style.fill: "#fde68a"
    }
  }

  per_symbol -> fr_agg -> fr_sel -> fr_outputs
}

# ─────────────────────────────────────────────
# Stage 3 – Data preparation
# ─────────────────────────────────────────────
prep: Data Preparation {
  style.fill: "#dcfce7"
  style.stroke: "#16a34a"

  dp_split: "Chronological split per symbol\ntrain · val · test" {
    shape: step
    style.fill: "#bbf7d0"
  }

  dp_fit: "Feature pipeline\nfit on train only\nWelford online normalisation" {
    shape: step
    style.fill: "#bbf7d0"
  }

  dp_cache: "Parquet cache\ndata/prepared/\ntrain · val · test per symbol" {
    shape: cylinder
    style.fill: "#86efac"
  }

  dp_mem: "Memmap files\ndata/memmap/\n{i}_train_data.npy  float32\n{i}_train_index.npy  int64\n{i}_columns.json" {
    shape: cylinder
    style.fill: "#86efac"
  }

  dp_split -> dp_fit -> dp_cache
  dp_fit -> dp_mem
}

# ─────────────────────────────────────────────
# Stage 4 – RL training
# ─────────────────────────────────────────────
train: RL Training {
  style.fill: "#fee2e2"
  style.stroke: "#dc2626"

  env: "StreamingTradingEnvXY\nreset(): shuffle symbol deck\npick random 50k-row window\nfrom that symbol's memmap" {
    shape: step
    style.fill: "#fecaca"
  }

  collector: "SyncDataCollector\ncollect frames_per_batch=200\ntransitions per update" {
    shape: step
    style.fill: "#fecaca"
  }

  buffer: "Replay Buffer\nLazyTensorStorage\nbuffer_size=100k transitions" {
    shape: queue
    style.fill: "#fca5a5"
  }

  td3: "TD3Loss\ntwin critics · clipped double Q\ndelayed actor update (every 2 steps)\ntarget policy smoothing σ=0.2" {
    shape: step
    style.fill: "#fecaca"
  }

  soft: "Soft target network update\nτ = 0.001" {
    shape: step
    style.fill: "#fecaca"
  }

  ckpt: "Checkpoint\nactor + twin critic weights\noptimizer state\nevery 100k steps" {
    shape: document
    style.fill: "#fca5a5"
  }

  env -> collector -> buffer -> td3 -> soft
  soft -> collector: "next batch"
  td3 -> ckpt
}

# ─────────────────────────────────────────────
# Stage 5 – Evaluation
# ─────────────────────────────────────────────
eval: Evaluation {
  style.fill: "#f3e8ff"
  style.stroke: "#9333ea"

  backtest: "Deterministic rollout\nno exploration noise\nfull val split · full test split" {
    shape: step
    style.fill: "#e9d5ff"
  }

  metrics: "Per-split metrics\nSharpe ratio · max drawdown\ntotal return · win rate\nposition change ratio" {
    shape: step
    style.fill: "#e9d5ff"
  }

  stats: "Statistical significance tests\nt-test · Sharpe bootstrap\nSortino bootstrap · Mann-Whitney\nvs buy-and-hold · TWAP · VWAP · random" {
    shape: step
    style.fill: "#e9d5ff"
  }

  expl: "Explainability\npermutation feature importance\nn_steps=500" {
    shape: step
    style.fill: "#e9d5ff"
  }

  mlflow: "MLflow\nparameters · metrics\nartifacts · plots" {
    shape: cylinder
    style.fill: "#c4b5fd"
  }

  backtest -> metrics -> stats -> mlflow
  backtest -> expl -> mlflow
}

# ─────────────────────────────────────────────
# Cross-stage connections
# ─────────────────────────────────────────────
acquire.parquet -> research.fr_split
acquire.parquet -> prep.dp_split

research.fr_yaml -> prep.dp_fit: "feeds reduced\nfeature config" {
  style.stroke-dash: 4
  style.stroke: "#ca8a04"
}

prep.dp_mem -> train.env: "memmap paths\nper symbol"
prep.dp_cache -> eval.backtest: "val + test\nDataFrames"
train.ckpt -> eval.backtest: "trained\nactor weights"
