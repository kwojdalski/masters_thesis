@article{Lyons2001,
abstract = {Though fundamental and technical analysis are still widely used in foreign exchange markets, a new type of analysis has emerged: or- der-flow analysis. Order-flow analysis uses the flow of buy and sell orders to both explain exchange rates contemporaneously and fore- cast future movements. This article contrasts order-flow analysis with the traditional approaches and reviews lessons learned. Most important among those lessons is order flow's ability to account for the lion's share of movements in the major floating rates. On the policy front, widespread availability of electronic order-flow data brings many policy questions within our reach for the first time. Af- ter reviewing these policy questions, the article closes with a dis- cussion of how FX market institutions are evolving and how this evolution will affect application of order-flow analysis in the future},
